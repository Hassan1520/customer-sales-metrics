<odoo>
    <record id="view_partner_sales_metrics_tree" model="ir.ui.view">
        <field name="name">res.partner.sales.metrics.tree</field>
        <field name="model">res.partner</field>
        <field name="arch" type="xml">
            <list default_order="total_sales desc" create="false">
                <field name="name" string="Customer Name"/>
                <field name="total_sales" string="Total Sales" widget="monetary"/>
                <field name="order_count" string="Orders Count"/>
            </list>
        </field>
    </record>

    <record id="action_customer_metrics" model="ir.actions.act_window">
        <field name="name">Top Customers</field>
        <field name="res_model">res.partner</field>
        <field name="view_mode">list</field>
        <field name="context">{'order_by': 'total_sales desc'}</field>
        <field name="domain">[('total_sales', '>', 0)]</field>
        <field name="view_id" ref="view_partner_sales_metrics_tree"/>
    </record>

    <menuitem id="menu_customer_metrics"
              name="Top Customers Dashboard"
              action="action_customer_metrics" sequence="10"/>
</odoo>